{
  "name": "@devioarts/capacitor-sqlite",
  "version": "0.0.2",
  "description": "SQLite database plugin for Capacitor",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.53.0-build1"
  },
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js",
      "default": "./dist/esm/index.js"
    },
    "./electron": {
      "types": "./electron/types-public/index.d.ts",
      "require": "./electron/dist/plugin.cjs.js",
      "default": "./electron/dist/plugin.cjs.js"
    },
    "./electron/settings": {
      "require": "./electron/dist/plugin-settings.js",
      "default": "./electron/dist/plugin-settings.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "electron/dist/",
    "electron/rollup.config.mjs",
    "electron/types-public/",
    "ios/Sources",
    "ios/Tests",
    "Package.swift",
    "CapacitorSqlite.podspec"
  ],
  "author": "ai@devioarts.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devioarts/capacitor-sqlite.git"
  },
  "bugs": {
    "url": "https://github.com/devioarts/capacitor-sqlite/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web && npm run verify:electron",
    "verify:ios": "swift build --sdk \"$(xcrun --sdk iphonesimulator --show-sdk-path)\" --triple \"$(uname -m)-apple-ios15.0-simulator\"",
    "verify:iosOriginal": "xcodebuild -scheme CapacitorSqlite -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "verify:electron": "npm run build:electron",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint Package.swift ios/Sources ios/Tests",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format Package.swift ios/Sources ios/Tests",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api CapacitorSqlitePlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.mjs && npm run build:electron",
    "build:electron": "tsc --project electron/tsconfig.json && rollup -c electron/rollup.config.mjs",
    "clean": "rimraf ./dist ./electron/dist ./electron/build",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "release": "npm publish --access public"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@types/node": "^24.0.0",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.0.0",
    "@ionic/eslint-config": "^0.4.0",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.7",
    "rimraf": "^6.1.0",
    "rollup": "^4.53.2",
    "swiftlint": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended",
    "parserOptions": {
      "project": [
        "./tsconfig.eslint.json",
        "./electron/tsconfig.json"
      ]
    }
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    },
    "electron": {
      "src": "electron"
    }
  }
}
