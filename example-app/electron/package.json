{
  "name": "capacitor-sqlite-example-electron",
  "version": "0.0.1",
  "type": "commonjs",
  "main": "dist/main.cjs",
  "dependencies": {
    "@devioarts/capacitor-sqlite": "file:../.."
  },
  "scripts": {
    "update": "npx --yes tsx cli/update.mts",
    "build:main": "esbuild main.ts --bundle --platform=node --external:electron --outfile=dist/main.cjs",
    "build:preload": "esbuild preload.ts --bundle --platform=node --external:electron --outfile=dist/preload.cjs",
    "build": "npm run build:main && npm run build:preload",
    "watch": "npm run build:main -- --watch",
    "dev:electron": "npm run build && wait-on http://localhost:5173 && electron dist/main.cjs",
    "start": "npm run build && electron dist/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "electron": "42.4.0",
    "wait-on": "^9.0.0"
  }
}
